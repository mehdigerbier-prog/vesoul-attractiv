  // Fenêtres
  [[-4.5,5.5],[-2.5,5.5],[-.5,5.5],[.5,5.5],[2.5,5.5],[4.5,5.5],[-4.5,3],[-2.5,3],[-.5,3],[.5,3],[2.5,3],[4.5,3]].forEach(([x,y])=>{

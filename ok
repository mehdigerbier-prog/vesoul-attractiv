function hideAllExcept(keep){
  ['questionnaire','results','randopage','agendapage','detpage'].forEach(id=>{
    if(id!==keep){const e=document.getElementById(id);if(e)e.style.display='none';}
  });
}
function switchTab(t){
  if(t==='search'){
    if(S.pois.length>0){hideAll();document.getElementById('results').style.display='block';S.filtered=[...S.pois];renderPOIs();}
    else goHome();
  }else if(t==='rando')showRando();
  else if(t==='map'){hideAll();document.getElementById('results').style.display='block';S.filtered=[...S.pois];renderPOIs();setTimeout(function(){if(S.map)S.map.invalidateSize();},150);}
  else if(t==='agenda')showAgenda();
  else if(t==='fav')showFavs();
  setNav(t);
}
function setNav(t){
  document.querySelectorAll('.bni').forEach(b=>b.classList.remove('on'));
  const e=document.getElementById('bn-'+t);if(e)e.classList.add('on');
}
function showLoader(tx,sb){const e=document.getElementById('loader');e.classList.remove('hidden');document.getElementById('ltxt').textContent=tx;document.getElementById('lsub').textContent=sb;}
function updLoader(tx,sb){document.getElementById('ltxt').textContent=tx;document.getElementById('lsub').textContent=sb;}
function hideLoader(){document.getElementById('loader').classList.add('hidden');}


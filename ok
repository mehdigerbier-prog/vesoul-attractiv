function renderQ(i){
  const q=QS[i],n=QS.length,pct=Math.round(i/n*100);
  document.getElementById('slbl').textContent=`Étape ${i+1} / ${n}`;
  document.getElementById('spct').textContent=pct+' %';
  document.getElementById('pfill').style.width=pct+'%';
  let h=`<div class="q-card"><div class="q-title">${q.t}</div><div class="q-sub">${q.s}</div>`;
  if(q.type==='single'){
    h+=`<div class="opt-grid">`;
    q.opts.forEach(o=>h+=`<button class="opt-btn${S.ans[q.k]===o.v?' sel':''}" onclick="sSingle('${q.k}','${o.v}',this)"><span class="ic">${o.i}</span><span>${o.l}</span></button>`);
    h+='</div>';
  }else if(q.type==='multi'){
    const cur=S.ans[q.k]||[];
    h+=`<div class="opt-grid">`;
    q.opts.forEach(o=>h+=`<button class="opt-btn${cur.includes(o.v)?' sel msel':''}" onclick="sMulti('${q.k}','${o.v}',this)"><span class="ic">${o.i}</span><span>${o.l}</span></button>`);
    h+='</div>';
  }else if(q.type==='slider'){
    const v=S.ans[q.k]||q.def,p=((v-q.min)/(q.max-q.min)*100).toFixed(1);
    h+=`<div class="slider-wrap"><div class="slider-labels"><span>${q.min} km</span><span>${q.max} km</span></div>
    <input type="range" id="sl-${q.id}" min="${q.min}" max="${q.max}" value="${v}" style="--pct:${p}%" oninput="uSlider('${q.k}','${q.id}',this)">
    <div class="slider-val" id="sv-${q.id}">${v} <span style="font-size:1rem;color:#64748b">km</span></div></div>`;
  }else if(q.type==='toggle'){
    const on=S.ans[q.k]||q.def;
    h+=`<div class="tgl-row${on?' on':''}" id="tg-${q.id}" onclick="uToggle('${q.k}','${q.id}')"><span class="tgl-label" style="font-weight:600">${q.lbl}</span><div class="tgl-sw"></div></div>`;
  }
  h+=`<div class="q-nav">`;
  if(i>0)h+=`<button class="btn-prev" onclick="prevQ()">← Retour</button>`;
  h+=(i<n-1)?`<button class="btn-next" onclick="nextQ()">Suivant →</button>`:`<button class="btn-next" onclick="submitQ()" style="background:linear-gradient(135deg,#22c55e,#16a34a)">🔍 Voir les résultats</button>`;
  h+='</div></div>';
  document.getElementById('qcont').innerHTML=h;
  document.getElementById('questionnaire').style.display='block';
  hideAllExcept('questionnaire');
}
function sSingle(k,v,b){S.ans[k]=v;b.closest('.opt-grid').querySelectorAll('.opt-btn').forEach(x=>x.classList.remove('sel'));b.classList.add('sel');}
function sMulti(k,v,b){if(!S.ans[k])S.ans[k]=[];const a=S.ans[k],i=a.indexOf(v);if(i===-1){a.push(v);b.classList.add('sel','msel');}else{a.splice(i,1);b.classList.remove('sel','msel');}}
function uSlider(k,id,inp){const v=+inp.value;S.ans[k]=v;const q=QS.find(x=>x.k===k);inp.style.setProperty('--pct',((v-q.min)/(q.max-q.min)*100)+'%');document.getElementById('sv-'+id).innerHTML=v+' <span style="font-size:1rem;color:#64748b">km</span>';}
function uToggle(k,id){S.ans[k]=!S.ans[k];document.getElementById('tg-'+id).classList.toggle('on',S.ans[k]);}
function nextQ(){S.step++;renderQ(S.step);}
function prevQ(){if(S.step>0){S.step--;renderQ(S.step);}}

// ═══════════════════════════════════════════════════
// SUBMIT → OVERPASS API
// ═══════════════════════════════════════════════════
async function submitQ(){
  document.getElementById('questionnaire').style.display='none';
  showLoad('Chargement des données OSM…','Interrogation Overpass API · '+(S.ans.rayon||30)+' km autour de Vesoul…');
  const r=(S.ans.rayon||30)*1000;
  const its=S.ans.interets||[];
  const cats=its.length>0?its:['restaurant','sport','nature','culture','attraction','lake','musee'];
  let filters=[];
  cats.forEach(c=>{if(CATS[c])filters=filters.concat(CATS[c].q);});
  filters=[...new Set([...filters,'tourism=attraction','tourism=viewpoint','tourism=museum','amenity=theatre','leisure=park'])];
  let nq='';
  filters.forEach(f=>{const[k,v]=f.split('=');nq+=`node["${k}"="${v}"](around:${r},${VL},${VN});\nway["${k}"="${v}"](around:${r},${VL},${VN});\n`;});
  const oq=`[out:json][timeout:30];\n(\n${nq});\nout center 200;`;
  try{
    updLoad('Requête Overpass…','Récupération POI OpenStreetMap…');
    const res=await fetch(OVP,{method:'POST',body:oq});
    if(!res.ok)throw new Error('HTTP '+res.status);
    const d=await res.json();
    updLoad('Traitement…',d.elements.length+' éléments · normalisation…');
    S.pois=procOVP(d.elements,S.ans);S.filtered=[...S.pois];S.ovpOk=true;
    await wait(400);hideLoad();showResults();
  }catch(e){
    console.warn('Overpass:',e);
    updLoad('Données locales…','API indisponible · données locales Vesoul');
    await wait(700);
    S.pois=getFallback(S.ans);S.filtered=[...S.pois];S.ovpOk=false;
    hideLoad();showResults();
  }
}

// ═══════════════════════════════════════════════════
// TRAITEMENT OVERPASS
// ═══════════════════════════════════════════════════
function procOVP(els,ans){
  const r=ans.rayon||30,pois=[];
  els.forEach(el=>{
    if(!el.tags)return;
    const lat=el.lat||el.center?.lat,lon=el.lon||el.center?.lon;
    if(!lat||!lon)return;
    const name=el.tags.name||el.tags['name:fr'];
    if(!name||name.length<2)return;
    const dist=hav(VL,VN,lat,lon);
    if(dist>r)return;
    const cat=detCat(el.tags);
    if(!cat)return;
    pois.push(enrich({
      id:String(el.id),name,category:cat,lat,lon,distance:dist,
      address:mkAddr(el.tags),website:el.tags.website||el.tags['contact:website'],
      phone:el.tags.phone||el.tags['contact:phone'],openingHours:el.tags.opening_hours,
      wheelchair:el.tags.wheelchair,description:el.tags.description,
      tags:el.tags,osmId:el.id,osmType:el.type,source:'OpenStreetMap'
    },ans));
  });
  return dedupe(pois).sort((a,b)=>b.score-a.score).slice(0,80);
}
function enrich(p,ans){
  p.carTimeMin=Math.max(5,Math.round(p.distance/60*60));
  p.carTime=p.carTimeMin+' min';
  p.score=calcScore(p.tags||{},ans,p.distance);
  p.transit=calcTransit(p,ans);
  p.gmLink=gLink(p.lat,p.lon,'driving');
  return p;
}
function detCat(t){
  if(t.amenity==='restaurant'||t.amenity==='fast_food'||t.amenity==='cafe')return'restaurant';
  if(t.amenity==='bar'||t.amenity==='pub'||t.amenity==='wine_bar')return'bar';
  if(t.leisure==='swimming_pool'||t.amenity==='swimming_pool')return'piscine';
  if(t.leisure==='sports_centre'||t.leisure==='stadium')return'sport';
  if(t.leisure==='spa'||t.amenity==='spa')return'bienetre';
  if(t.tourism==='museum')return'musee';
  if(t.amenity==='theatre'||t.amenity==='cinema')return'culture';
  if(t.historic)return'culture';
  if(t.tourism==='viewpoint'||t.tourism==='attraction')return'attraction';
  if(t.leisure==='park'||t.leisure==='nature_reserve')return'nature';
  if(t.natural==='peak')return'nature';
  if(t.natural==='water')return'lake';
  if(t.tourism==='camp_site'||t.tourism==='hotel'||t.tourism==='hostel')return'camping';
  if(t.amenity==='marketplace')return'shopping';
  if(t.tourism)return'attraction';
  if(t.leisure)return'nature';
  return null;
}
function mkAddr(t){const p=[];if(t['addr:housenumber'])p.push(t['addr:housenumber']);if(t['addr:street'])p.push(t['addr:street']);if(t['addr:city'])p.push(t['addr:city']);return p.join(', ')||'Adresse non renseignée (source OSM)';}
function calcScore(tags,ans,dist){
  let s=100-dist*.5;
  const cat=detCat(tags),its=ans.interets||[];
  if(its.includes(cat))s+=40;
  if(ans.mobilite==='transports'&&dist<5)s+=30;if(ans.mobilite==='transports'&&dist>20)s-=20;
  if(ans.budget==='gratuit'&&tags.fee==='no')s+=25;if(ans.budget==='gratuit'&&tags.fee==='yes')s-=30;
  if(ans.profil==='famille'&&(cat==='nature'||cat==='lake'))s+=15;
  if(ans.temps==='soiree'&&(cat==='bar'||cat==='culture'))s+=25;if(ans.temps==='soiree'&&cat==='musee')s-=20;
  if(ans.original&&(tags.tourism==='viewpoint'||cat==='attraction'))s+=35;
  if(ans.ambiance==='sportif'&&cat==='sport')s+=30;
  if(ans.ambiance==='calme'&&(cat==='nature'||cat==='bienetre'))s+=25;
  if(ans.ambiance==='decouverte'&&(cat==='musee'||cat==='culture'))s+=25;
  if(ans.ambiance==='fun'&&(cat==='bar'||cat==='sport'))s+=20;
  if(ans.contraintes?.includes('pmr')&&tags.wheelchair==='yes')s+=20;
  if(ans.contraintes?.includes('pmr')&&tags.wheelchair==='no')s-=40;
  if(tags.name)s+=10;if(tags.website)s+=5;
  return Math.max(0,s);
}
function calcTransit(p,ans){
  const d=p.distance,lk=gLink(p.lat,p.lon,'transit');
  if(d<=15)return{ok:true,dur:Math.round(d*4+15)+' min',lines:d<5?['L1','L3']:['L2'],walk:Math.round(d*.8*10)+' min',note:'Estimation réseau Moova (mode dégradé — sans OpenTripPlanner). Vérifier horaires sur moova.fr ou Google Maps.',lk};
  if(d<=30)return{ok:true,dur:Math.round(d*3.5+20)+' min',lines:['Moova + correspondance'],walk:Math.round(d*.3*10)+' min',note:'Itinéraire approximatif — vérifier sur moova.fr ou Google Maps Transports.',lk};
  return{ok:false,note:'Distance > 30 km — hors périmètre réseau Moova. Voiture recommandée.'};
}
function dedupe(p){const s=new Map();return p.filter(x=>{const k=x.name.toLowerCase().replace(/\s/g,'').slice(0,12)+'_'+Math.round(x.lat*100)+'_'+Math.round(x.lon*100);if(s.has(k))return false;s.set(k,true);return true;});}
function hav(a,b,c,d){const R=6371,dl=(c-a)*Math.PI/180,dn=(d-b)*Math.PI/180,x=Math.sin(dl/2)**2+Math.cos(a*Math.PI/180)*Math.cos(c*Math.PI/180)*Math.sin(dn/2)**2;return R*2*Math.atan2(Math.sqrt(x),Math.sqrt(1-x));}
function gLink(lat,lon,mode){return`https://www.google.com/maps/dir/?api=1&origin=${VL},${VN}&destination=${lat},${lon}&travelmode=${mode}`;}
function wait(ms){return new Promise(r=>setTimeout(r,ms));}


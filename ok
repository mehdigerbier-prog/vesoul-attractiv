  window.addEventListener('resize',()=>{cam.aspect=innerWidth/innerHeight;cam.updateProjectionMatrix();R.setSize(innerWidth,innerHeight);});

  let t=0;
  (function tick(){requestAnimationFrame(tick);t+=.01;
    tx+=(mx-tx)*.04;ty+=(my-ty)*.04;
    G.rotation.y=tx*.25;G.rotation.x=ty*.08;
    G.position.y=Math.sin(t*.45)*.12;

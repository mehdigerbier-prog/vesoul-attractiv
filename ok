    h+='<div class="sw-wrap"><div class="sw-lbls"><span>'+q.min+' km</span><span>'+q.max+' km</span></div>'
      +'<input type="range" id="sl'+q.id+'" min="'+q.min+'" max="'+q.max+'" value="'+v+'" style="--p2:'+p2+'%" oninput="us(\''+q.k+'\',\''+q.id+'\',this)">'
      +'<div class="sw-val" id="sv'+q.id+'">'+v+' <span style="font-size:.9rem;color:#64748b">km</span></div></div>';
  }else if(q.tp==='toggle'){
    const on=S.ans[q.k]||q.def;
    h+='<div class="trow'+(on?' on':'')+'" id="tr'+q.id+'" onclick="ut(\''+q.k+'\',\''+q.id+'\')">'
      +'<span style="font-weight:600;font-size:.9rem">'+q.lbl+'</span>'

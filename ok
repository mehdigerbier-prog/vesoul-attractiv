  buildFilters();initMap();renderPOIs();setNav('search');
}

function buildFilters(){
  const cats=[...new Set(S.pois.map(p=>p.category))];
  let h=`<button class="f-chip active" onclick="fAll(this)">Tous</button>`;
  cats.forEach(c=>{const ct=CATS[c];if(ct)h+=`<button class="f-chip" onclick="fCat('${c}',this)">${ct.i} ${ct.l}</button>`;});
  h+=`<button class="f-chip" onclick="fBus(this)">🚌 En bus</button><button class="f-chip" onclick="fFree(this)">🆓 Gratuit</button>`;
  document.getElementById('fbar').innerHTML=h;
}
function fAll(b){S.filtered=[...S.pois];actF(b);renderPOIs();updMarkers();}
function fCat(c,b){S.filtered=S.pois.filter(p=>p.category===c);actF(b);renderPOIs();updMarkers();}
function fBus(b){S.filtered=S.pois.filter(p=>p.transit?.ok);actF(b);renderPOIs();updMarkers();}
function fFree(b){S.filtered=S.pois.filter(p=>!p.tags?.fee||p.tags.fee==='no');actF(b);renderPOIs();updMarkers();}
function actF(b){document.querySelectorAll('.f-chip').forEach(x=>x.classList.remove('active'));b.classList.add('active');}
function doSort(){const v=document.getElementById('sortsel').value;const p=[...S.filtered];if(v==='score')p.sort((a,b)=>b.score-a.score);else if(v==='distance')p.sort((a,b)=>a.distance-b.distance);else p.sort((a,b)=>a.name.localeCompare(b.name));S.filtered=p;renderPOIs();}
function renderPOIs(){
  const l=document.getElementById('poilist');

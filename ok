}
function ss(k,v,b){S.ans[k]=v;b.closest('.og').querySelectorAll('.ob').forEach(x=>x.classList.remove('on'));b.classList.add('on');}
function sm(k,v,b){if(!S.ans[k])S.ans[k]=[];const a=S.ans[k],i=a.indexOf(v);if(i===-1){a.push(v);b.classList.add('on','mon');}else{a.splice(i,1);b.classList.remove('on','mon');}}
function us(k,id,inp){const v=+inp.value;S.ans[k]=v;const q=QS.find(x=>x.k===k);inp.style.setProperty('--p2',((v-q.min)/(q.max-q.min)*100)+'%');document.getElementById('sv'+id).innerHTML=v+' <span style="font-size:.9rem;color:#64748b">km</span>';}
function ut(k,id){S.ans[k]=!S.ans[k];document.getElementById('tr'+id).classList.toggle('on',S.ans[k]);}

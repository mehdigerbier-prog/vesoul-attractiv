<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Que faire autour de Vesoul ?</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
:root{--p:#1a3a5c;--a:#e8622a;--l:#f5f7fa;--w:#fff;--sh:0 4px 20px rgba(0,0,0,.12);--r:16px}
*{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;min-height:100vh;font-family:'Segoe UI',system-ui,sans-serif;background:var(--l);color:#1a1a2e;overflow-x:hidden}

/* ── LANDING ── */
#landing{
  width:100%;height:100vh;
  background:linear-gradient(135deg,#0a1628 0%,#1a3a5c 50%,#0d2137 100%);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  position:relative;overflow:hidden;
}
#canvas3d{position:absolute;top:0;left:0;width:100%;height:100%;z-index:1}
.lc{position:relative;z-index:2;text-align:center;padding:0 24px;animation:fadeUp .8s ease both}
@keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
.hero-badge{display:inline-block;background:rgba(232,98,42,.2);border:1px solid rgba(232,98,42,.5);color:#ffaa80;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;padding:6px 16px;border-radius:20px;margin-bottom:20px}
.hero-title{font-size:clamp(2.2rem,6vw,4.5rem);font-weight:900;color:#fff;line-height:1.05;margin-bottom:16px;text-shadow:0 4px 30px rgba(0,0,0,.6)}
.hero-title span{color:#e8622a}
.hero-sub{font-size:clamp(.95rem,2vw,1.2rem);color:rgba(255,255,255,.7);max-width:540px;margin:0 auto 36px;line-height:1.6}
.btn-cta{display:inline-flex;align-items:center;gap:10px;background:#e8622a;color:#fff;font-size:1.05rem;font-weight:700;padding:15px 34px;border-radius:50px;border:none;cursor:pointer;box-shadow:0 8px 30px rgba(232,98,42,.5);transition:all .2s;text-decoration:none}
.btn-cta:hover{transform:translateY(-3px);box-shadow:0 12px 40px rgba(232,98,42,.6)}
.landing-meta{margin-top:20px;color:rgba(255,255,255,.3);font-size:.72rem}
.ptcl{position:absolute;width:2px;height:2px;background:rgba(255,255,255,.5);border-radius:50%;animation:rise linear infinite;z-index:1}
@keyframes rise{from{transform:translateY(100vh)}to{transform:translateY(-10vh)}}

/* ── APP ── */
#app{display:none;min-height:100vh;width:100%}

/* NAV */
.topnav{position:sticky;top:0;z-index:500;background:rgba(26,58,92,.96);backdrop-filter:blur(10px);padding:13px 20px;display:flex;align-items:center;gap:10px;box-shadow:0 2px 15px rgba(0,0,0,.25)}
.topnav-logo{color:#fff;font-weight:800;font-size:.95rem;flex:1}.topnav-logo em{color:#e8622a;font-style:normal}
.tnbtn{background:none;border:none;color:rgba(255,255,255,.65);cursor:pointer;padding:7px 10px;border-radius:8px;font-size:.8rem;font-weight:600;transition:all .2s}
.tnbtn:hover{color:#fff;background:rgba(255,255,255,.12)}

/* QUESTIONNAIRE */
#questionnaire{max-width:660px;margin:0 auto;padding:24px 18px 90px;width:100%}
.prog-wrap{margin-bottom:28px}
.prog-row{display:flex;justify-content:space-between;font-size:.75rem;color:#64748b;font-weight:600;margin-bottom:7px}
.prog-track{background:#e2e8f0;border-radius:6px;height:5px}
.prog-bar{height:100%;background:linear-gradient(90deg,#e8622a,#ff9060);border-radius:6px;transition:width .4s}
.qcard{background:var(--w);border-radius:var(--r);padding:26px 22px;box-shadow:var(--sh);animation:sIn .25s ease}
@keyframes sIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.qtitle{font-size:1.35rem;font-weight:700;color:var(--p);margin-bottom:6px}
.qsub{font-size:.85rem;color:#64748b;margin-bottom:22px}
.og{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.ob{display:flex;flex-direction:column;align-items:center;gap:7px;padding:14px 10px;border:2px solid #e2e8f0;border-radius:11px;background:#fff;cursor:pointer;transition:all .18s;font-size:.82rem;font-weight:600;color:#334155;text-align:center}
.ob .em{font-size:1.7rem}
.ob:hover{border-color:#e8622a;background:#fff6f2;color:#e8622a}
.ob.on{border-color:#e8622a;background:#fff6f2;color:#e8622a}
.ob.mon{border-color:var(--p);background:#eff6ff;color:var(--p)}
.sw-wrap{padding:14px 0}
.sw-lbls{display:flex;justify-content:space-between;font-size:.75rem;color:#64748b;margin-bottom:7px}
.sw-val{text-align:center;font-size:1.7rem;font-weight:800;color:#e8622a;margin-top:10px}
input[type=range]{width:100%;-webkit-appearance:none;height:5px;background:linear-gradient(90deg,#e8622a var(--p2,50%),#e2e8f0 var(--p2,50%));border-radius:4px;outline:none;cursor:pointer}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:20px;height:20px;background:#e8622a;border-radius:50%;box-shadow:0 2px 8px rgba(232,98,42,.4)}
.trow{display:flex;align-items:center;justify-content:space-between;padding:15px;border:2px solid #e2e8f0;border-radius:11px;cursor:pointer;transition:all .2s}
.trow.on{border-color:#e8622a;background:#fff6f2}
.tknob{width:44px;height:24px;background:#e2e8f0;border-radius:12px;position:relative;transition:background .2s;flex-shrink:0}
.tknob::after{content:'';position:absolute;top:2px;left:2px;width:20px;height:20px;background:#fff;border-radius:50%;transition:transform .2s;box-shadow:0 1px 4px rgba(0,0,0,.2)}
.trow.on .tknob{background:#e8622a}.trow.on .tknob::after{transform:translateX(20px)}
.qnav{display:flex;gap:10px;margin-top:20px}
.bprev{padding:13px 18px;border-radius:50px;border:2px solid #e2e8f0;background:#fff;cursor:pointer;font-weight:600;color:#64748b;transition:all .2s}
.bprev:hover{border-color:var(--p);color:var(--p)}
.bnext{flex:1;padding:13px;border-radius:50px;border:none;background:linear-gradient(135deg,#e8622a,#ff7a40);color:#fff;font-size:.95rem;font-weight:700;cursor:pointer;box-shadow:0 4px 14px rgba(232,98,42,.35);transition:all .2s}
.bnext:hover{transform:translateY(-2px)}

/* RÉSULTATS */
#results{display:none;width:100%}
.rh{background:var(--p);color:#fff;padding:18px 20px}
.rh-title{font-size:1.25rem;font-weight:700;margin-bottom:3px}
.rh-sub{font-size:.8rem;color:rgba(255,255,255,.65)}
.apist{display:flex;align-items:center;gap:6px;font-size:.75rem;padding:6px 10px;border-radius:7px;margin-top:8px;width:fit-content}
.apist.ok{background:rgba(34,197,94,.2);color:#86efac}
.apist.ko{background:rgba(239,68,68,.2);color:#fca5a5}
.apidot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.fbar{background:#fff;padding:14px 18px;border-bottom:1px solid #eee;display:flex;gap:7px;overflow-x:auto;scrollbar-width:none;-webkit-overflow-scrolling:touch}
.fbar::-webkit-scrollbar{display:none}
.fchip{flex-shrink:0;padding:7px 14px;border-radius:18px;border:2px solid #e2e8f0;background:#fff;font-size:.77rem;font-weight:600;cursor:pointer;color:#64748b;white-space:nowrap;transition:all .18s}
.fchip.on{border-color:var(--p);background:var(--p);color:#fff}
#mapbox{height:240px}
#themap{height:100%}
.oattr{font-size:.68rem;color:#94a3b8;padding:3px 10px;background:#f8fafc;border-top:1px solid #eee;text-align:right}
.oattr a{color:#94a3b8}
.srow{background:#fff;padding:11px 18px;display:flex;align-items:center;gap:10px;border-bottom:1px solid #eee}
.ssel{flex:1;padding:7px 10px;border:1px solid #e2e8f0;border-radius:7px;font-size:.82rem;color:#334155;outline:none}
.rcnt{font-size:.77rem;color:#64748b;font-weight:600;margin-left:auto}
.plist{padding:14px 18px;display:grid;gap:14px;padding-bottom:80px}
.pcard{background:var(--w);border-radius:var(--r);overflow:hidden;box-shadow:var(--sh);cursor:pointer;transition:transform .18s,box-shadow .18s}
.pcard:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,0,0,.14)}
.ph{padding:14px;display:flex;gap:12px;align-items:flex-start}
.pic{width:48px;height:48px;border-radius:11px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:1.5rem}
.pi{flex:1;min-width:0}
.pname{font-weight:700;font-size:.95rem;color:#1a1a2e;margin-bottom:3px;line-height:1.2}
.pmeta{font-size:.74rem;color:#64748b;margin-bottom:6px}
.bdgs{display:flex;gap:5px;flex-wrap:wrap}
.bdg{font-size:.65rem;font-weight:700;padding:2px 7px;border-radius:5px;text-transform:uppercase}
.bg{background:#dcfce7;color:#15803d}.bb{background:#dbeafe;color:#1d4ed8}.bo{background:#fef3c7;color:#b45309}
.ptr{padding:9px 14px;background:#f8fafc;border-top:1px solid #f0f0f0;display:grid;grid-template-columns:1fr 1fr;gap:7px}
.ti{display:flex;align-items:center;gap:5px;font-size:.74rem;color:#64748b}
.pact{padding:11px 14px;display:flex;gap:7px}
.bgm{flex:1;padding:9px;border-radius:9px;border:none;background:#4285f4;color:#fff;font-size:.77rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:5px;text-decoration:none;transition:background .18s}
.bgm:hover{background:#1a73e8}
.bgm.tr{background:#34a853}.bgm.tr:hover{background:#0d7a3e}
.bdet{padding:9px 13px;border-radius:9px;border:2px solid #e2e8f0;background:#fff;font-size:.77rem;font-weight:700;cursor:pointer;color:#64748b;transition:all .18s}
.bdet:hover{border-color:var(--p);color:var(--p)}
.dnotice{background:#fffbeb;border:1px solid #fcd34d;border-radius:9px;padding:9px 13px;margin:0 18px 12px;font-size:.75rem;color:#92400e;line-height:1.5}

/* DETAIL */
#detpage{display:none;position:fixed;inset:0;background:var(--l);z-index:800;overflow-y:auto}
.dth{background:var(--p);color:#fff;padding:18px 20px;position:sticky;top:0;z-index:10;display:flex;align-items:center;gap:10px}
.dtback{background:rgba(255,255,255,.15);border:none;color:#fff;width:36px;height:36px;border-radius:50%;font-size:1.1rem;cursor:pointer;display:flex;align-items:center;justify-content:center}
.dtback:hover{background:rgba(255,255,255,.25)}
.dtbody{padding:18px;max-width:660px;margin:0 auto}
.dsec{background:var(--w);border-radius:var(--r);padding:18px;margin-bottom:14px;box-shadow:0 2px 10px rgba(0,0,0,.06)}
.dstl{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:#e8622a;margin-bottom:12px}
.dr{display:flex;gap:10px;padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:.85rem}
.dr:last-child{border-bottom:none;padding-bottom:0}
.dric{font-size:1rem;flex-shrink:0;margin-top:1px}
.dlbl{color:#94a3b8;font-size:.74rem}.dval{font-weight:600;color:#1a1a2e}.dsub2{font-size:.72rem;color:#64748b;margin-top:1px}
.bbig{display:flex;align-items:center;justify-content:center;gap:7px;width:100%;padding:13px;border-radius:11px;border:none;font-size:.9rem;font-weight:700;cursor:pointer;margin-bottom:9px;text-decoration:none;transition:all .18s}
.bbig.car{background:#4285f4;color:#fff}.bbig.car:hover{background:#1a73e8}
.bbig.trs{background:#34a853;color:#fff}.bbig.trs:hover{background:#0d7a3e}
.bbig.src{background:#ff5252;color:#fff}
.ngrid{display:grid;grid-template-columns:1fr 1fr;gap:9px}
.nc{background:var(--l);border-radius:9px;padding:10px;cursor:pointer;border:1px solid #e2e8f0;transition:all .18s;display:flex;align-items:center;gap:8px}
.nc:hover{border-color:var(--p);background:#eff6ff}

/* RANDO */
#randopage{display:none;padding-bottom:80px;width:100%}
.rcard{margin:0 18px 14px;background:var(--w);border-radius:var(--r);box-shadow:var(--sh);overflow:hidden}
.rbanner{height:90px;display:flex;align-items:center;justify-content:center;font-size:2.8rem;position:relative}
.rdiff{position:absolute;top:10px;right:10px;padding:3px 9px;border-radius:7px;font-size:.72rem;font-weight:700;background:rgba(0,0,0,.5);color:#fff}
.rbody{padding:14px}
.rname{font-size:1rem;font-weight:700;color:var(--p);margin-bottom:7px}
.rstats{display:flex;gap:14px;margin-bottom:10px;flex-wrap:wrap}
.rstat{font-size:.78rem;color:#64748b}.rstat strong{color:#334155}
.rwarn{font-size:.72rem;color:#92400e;background:#fef3c7;border-radius:7px;padding:7px 9px;margin-top:8px}

/* AGENDA */
#agendapage{display:none;padding:18px;padding-bottom:80px;width:100%}
.asrc{display:flex;gap:9px;padding:9px;border-radius:7px;background:var(--l);margin-bottom:7px;font-size:.8rem;text-align:left;align-items:flex-start}
.adot{width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:4px}
.dok{background:#22c55e}.dpend{background:#f59e0b}.dmiss{background:#ef4444}

/* LOADING */
.loader{position:fixed;inset:0;background:rgba(26,58,92,.93);z-index:900;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:18px;color:#fff}
.spin{width:48px;height:48px;border:4px solid rgba(255,255,255,.2);border-top-color:#e8622a;border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.ltxt{font-size:.95rem;font-weight:600}
.lsub{font-size:.77rem;opacity:.6;text-align:center;max-width:260px}

/* BOTTOM NAV */
.bnav{position:fixed;bottom:0;left:0;right:0;z-index:500;background:rgba(255,255,255,.97);backdrop-filter:blur(10px);border-top:1px solid #e2e8f0;display:flex;box-shadow:0 -3px 15px rgba(0,0,0,.08)}
.bni{flex:1;display:flex;flex-direction:column;align-items:center;padding:9px 4px 5px;cursor:pointer;color:#94a3b8;font-size:.62rem;font-weight:600;gap:2px;border:none;background:none;text-transform:uppercase;letter-spacing:.4px;transition:color .18s}
.bni .ico{font-size:1.35rem}
.bni.on{color:#e8622a}

/* EMPTY */
.empty{text-align:center;padding:44px 20px;color:#94a3b8}
.empty .eic{font-size:2.8rem;margin-bottom:10px}
.empty h3{font-size:1rem;font-weight:700;color:#64748b;margin-bottom:6px}

.hidden{display:none!important}
</style>
</head>
<body>

<!-- ════ LANDING ════ -->
<div id="landing">
  <canvas id="canvas3d"></canvas>
  <div id="ptcls"></div>
  <div class="lc">
    <div class="hero-badge">✨ Anti-ennui · Vesoul &amp; Haute-Saône</div>
    <h1 class="hero-title">Que faire<br>autour de <span>Vesoul</span>&nbsp;?</h1>
    <p class="hero-sub">Activités, restaurants, randonnées, bien-être… jusqu'à 60 km. Itinéraires voiture &amp; transports Moova.</p>
    <button class="btn-cta" onclick="startApp()">Commencer le questionnaire →</button>
    <div class="landing-meta">OpenStreetMap · Moova GTFS · Open Data</div>
  </div>
</div>

<!-- ════ LOADER ════ -->
<div class="loader hidden" id="loader">
  <div class="spin"></div>
  <div class="ltxt" id="ltxt">Chargement…</div>
  <div class="lsub" id="lsub">Interrogation Overpass API…</div>
</div>

<!-- ════ APP ════ -->
<div id="app">
  <nav class="topnav">
    <div class="topnav-logo">Vesoul <em>Anti-Ennui</em></div>
    <button class="tnbtn" onclick="goHome()">🏠</button>
    <button class="tnbtn" onclick="showRando()">🥾</button>
    <button class="tnbtn" onclick="showAgenda()">📅</button>
    <button class="tnbtn" onclick="showFavs()">❤️</button>
  </nav>

  <!-- Questionnaire -->
  <div id="questionnaire">
    <div class="prog-wrap">
      <div class="prog-row"><span id="slbl">Étape 1 / 9</span><span id="spct">0 %</span></div>
      <div class="prog-track"><div class="prog-bar" id="pbar" style="width:11%"></div></div>
    </div>
    <div id="qcont"></div>
  </div>

  <!-- Résultats -->
  <div id="results">
    <div class="rh">
      <div class="rh-title" id="rtitle">Résultats</div>
      <div class="rh-sub" id="rsub">Chargement…</div>
      <div id="apist"></div>
    </div>
    <div class="fbar" id="fbar"></div>
    <div id="mapbox"><div id="themap"></div></div>
    <div class="oattr">Carte : © <a href="https://www.openstreetmap.org/copyright" target="_blank">OpenStreetMap</a> contributors</div>
    <div class="srow">
      <span style="font-size:.77rem;color:#64748b;font-weight:600;white-space:nowrap">Trier :</span>
      <select class="ssel" id="sortsel" onchange="doSort()">
        <option value="score">Recommandé</option>
        <option value="distance">Plus proche</option>
        <option value="name">Alphabétique</option>
      </select>
      <span class="rcnt" id="rcnt"></span>
    </div>
    <div class="dnotice">ℹ️ Données <strong>OpenStreetMap</strong> via Overpass API. Infos manquantes → "Non disponible" (jamais inventées).</div>
    <div class="plist" id="plist"></div>
  </div>

  <!-- Détail -->
  <div id="detpage">
    <div class="dth">
      <button class="dtback" onclick="closeDet()">←</button>
      <span id="dttitle" style="font-size:1.05rem;font-weight:700">Détails</span>
    </div>
    <div class="dtbody" id="dtbody"></div>
  </div>

  <!-- Randonnées -->
  <div id="randopage">
    <div class="rh">
      <div class="rh-title">🥾 Randonnées</div>
      <div class="rh-sub">Circuits autour de Vesoul · OSM &amp; terrain</div>
    </div>
    <div class="fbar" id="rfbar"></div>
    <div id="rlist" style="padding:14px 0"></div>
  </div>

  <!-- Agenda -->
  <div id="agendapage">
    <h2 style="font-size:1.15rem;font-weight:800;color:var(--p);margin-bottom:14px">📅 Agenda local</h2>
    <div style="background:#fff;border-radius:var(--r);padding:26px;box-shadow:var(--sh);text-align:center">
      <div style="font-size:2.8rem;margin-bottom:10px">📅</div>
      <div style="font-size:1.05rem;font-weight:700;color:var(--p);margin-bottom:7px">Module Agenda prêt à connecter</div>
      <div style="font-size:.82rem;color:#64748b;line-height:1.6;margin-bottom:18px">Les données ne sont jamais inventées. Ce module est préparé pour recevoir des flux officiels vérifiés.</div>
      <div style="text-align:left">
        <div style="font-size:.77rem;font-weight:700;color:#64748b;margin-bottom:7px;text-transform:uppercase;letter-spacing:1px">Sources à connecter</div>
        <div class="asrc"><div class="adot dpend"></div><div><strong>Office de Tourisme Vesoul-Val de Saône</strong><br><span style="color:#64748b">Flux ICS/JSON officiel — en attente</span></div></div>
        <div class="asrc"><div class="adot dpend"></div><div><strong>vesoul.fr/agenda</strong><br><span style="color:#64748b">Scraping ou API municipale requise</span></div></div>
        <div class="asrc"><div class="adot dmiss"></div><div><strong>Événements OSM node[event]</strong><br><span style="color:#64748b">Données rares — en veille</span></div></div>
        <div class="asrc"><div class="adot dok"></div><div><strong>data.gouv.fr — Culture Haute-Saône</strong><br><span style="color:#64748b">API disponible — prêt à importer</span></div></div>
      </div>
    </div>
  </div>

  <!-- Bottom Nav -->
  <nav class="bnav">
    <button class="bni on" id="bn-search" onclick="switchTab('search')"><span class="ico">🔍</span>Chercher</button>
    <button class="bni" id="bn-rando" onclick="switchTab('rando')"><span class="ico">🥾</span>Rando</button>
    <button class="bni" id="bn-map" onclick="switchTab('map')"><span class="ico">🗺️</span>Carte</button>
    <button class="bni" id="bn-agenda" onclick="switchTab('agenda')"><span class="ico">📅</span>Agenda</button>
    <button class="bni" id="bn-fav" onclick="switchTab('fav')"><span class="ico">❤️</span>Favoris</button>
  </nav>
</div>

<script>
// ══ CONSTANTES ══
const VL=47.6195,VN=6.1542,OVP='https://overpass-api.de/api/interpreter';
const CATS={
  restaurant:{l:'Restaurant',i:'🍽️',c:'#fff5f0',b:'#fed7aa',q:['amenity=restaurant','amenity=fast_food','amenity=cafe']},
  bar:{l:'Bar',i:'🍺',c:'#fef9ef',b:'#fde68a',q:['amenity=bar','amenity=pub']},
  sport:{l:'Sport',i:'⚽',c:'#f0fdf4',b:'#bbf7d0',q:['leisure=sports_centre']},
  piscine:{l:'Piscine',i:'🏊',c:'#eff6ff',b:'#bfdbfe',q:['leisure=swimming_pool']},
  nature:{l:'Nature',i:'🌿',c:'#f0fdf4',b:'#bbf7d0',q:['leisure=park','natural=peak']},
  culture:{l:'Culture',i:'🏛️',c:'#faf5ff',b:'#e9d5ff',q:['amenity=theatre','amenity=cinema','historic=castle']},

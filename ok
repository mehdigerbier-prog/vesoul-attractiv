<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Que faire autour de Vesoul ?</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
:root{--primary:#1a3a5c;--accent:#e8622a;--light:#f5f7fa;--card-bg:#fff;--shadow:0 4px 20px rgba(0,0,0,.12);--radius:16px;--font:'Segoe UI',system-ui,sans-serif}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--font);background:var(--light);color:#1a1a2e;overflow-x:hidden}
#landing{position:relative;height:100vh;overflow:hidden;background:linear-gradient(135deg,#0a1628,#1a3a5c,#0d2137);display:flex;flex-direction:column;align-items:center;justify-content:center}
#canvas3d{position:absolute;inset:0;width:100%;height:100%}
.lc{position:relative;z-index:10;text-align:center;padding:0 24px;animation:fadeUp 1s ease both}
@keyframes fadeUp{from{opacity:0;transform:translateY(40px)}to{opacity:1;transform:translateY(0)}}
.badge-hero{display:inline-block;background:rgba(232,98,42,.15);border:1px solid rgba(232,98,42,.4);color:#f0a070;font-size:12px;font-weight:600;letter-spacing:2px;text-transform:uppercase;padding:6px 16px;border-radius:20px;margin-bottom:20px}
h1.hero{font-size:clamp(2rem,6vw,4rem);font-weight:800;color:#fff;line-height:1.1;margin-bottom:16px;text-shadow:0 2px 20px rgba(0,0,0,.5)}
h1.hero span{color:#e8622a}
.hero-sub{font-size:clamp(1rem,2.5vw,1.2rem);color:rgba(255,255,255,.75);max-width:560px;margin:0 auto 36px}
.btn-cta{display:inline-flex;align-items:center;gap:10px;background:#e8622a;color:#fff;font-size:1.1rem;font-weight:700;padding:16px 36px;border-radius:50px;border:none;cursor:pointer;box-shadow:0 8px 30px rgba(232,98,42,.45);transition:all .25s}
.btn-cta:hover{transform:translateY(-3px) scale(1.02);box-shadow:0 12px 40px rgba(232,98,42,.55)}
.scroll-hint{position:absolute;bottom:32px;left:50%;transform:translateX(-50%);color:rgba(255,255,255,.4);font-size:11px;text-align:center;z-index:10;animation:bounce 2s infinite}
@keyframes bounce{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(-8px)}}
.particle{position:absolute;width:2px;height:2px;background:rgba(255,255,255,.4);border-radius:50%;animation:floatUp linear infinite}
@keyframes floatUp{from{transform:translateY(100vh) scale(0)}to{transform:translateY(-100px) scale(1)}}
#app{display:none;min-height:100vh}
.nav{position:sticky;top:0;z-index:1000;background:rgba(26,58,92,.97);backdrop-filter:blur(12px);padding:14px 20px;display:flex;align-items:center;gap:12px;box-shadow:0 2px 20px rgba(0,0,0,.2)}
.nav-logo{color:#fff;font-weight:800;flex:1}.nav-logo span{color:#e8622a}
.nav-btn{background:none;border:none;color:rgba(255,255,255,.7);cursor:pointer;padding:8px;border-radius:8px;font-size:13px;font-weight:600;transition:all .2s}
.nav-btn:hover{color:#fff;background:rgba(255,255,255,.1)}
#questionnaire{max-width:680px;margin:0 auto;padding:24px 20px 80px}
.prog-bar{background:#e2e8f0;border-radius:8px;height:6px;margin-bottom:32px}
.prog-fill{height:100%;background:linear-gradient(90deg,#e8622a,#ff8c5a);border-radius:8px;transition:width .4s}
.step-ind{display:flex;justify-content:space-between;margin-bottom:8px;font-size:12px;color:#64748b;font-weight:600}
.q-card{background:var(--card-bg);border-radius:var(--radius);padding:28px 24px;box-shadow:var(--shadow);animation:slideIn .3s ease}
@keyframes slideIn{from{opacity:0;transform:translateX(20px)}to{opacity:1;transform:translateX(0)}}
.q-title{font-size:1.4rem;font-weight:700;color:var(--primary);margin-bottom:8px}
.q-sub{font-size:.9rem;color:#64748b;margin-bottom:24px}
.opt-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.opt-btn{display:flex;flex-direction:column;align-items:center;gap:8px;padding:16px 12px;border:2px solid #e2e8f0;border-radius:12px;background:#fff;cursor:pointer;transition:all .2s;font-size:.85rem;font-weight:600;color:#334155}
.opt-btn .ic{font-size:1.8rem}
.opt-btn:hover,.opt-btn.sel{border-color:#e8622a;background:#fff5f0;color:#e8622a}
.opt-btn.msel{border-color:var(--primary);background:#eff6ff;color:var(--primary)}
.slider-wrap{padding:16px 0}
.slider-labels{display:flex;justify-content:space-between;font-size:12px;color:#64748b;margin-bottom:8px}
.slider-val{text-align:center;font-size:1.8rem;font-weight:800;color:#e8622a;margin-top:12px}
input[type=range]{width:100%;-webkit-appearance:none;height:6px;background:linear-gradient(90deg,#e8622a var(--pct,50%),#e2e8f0 var(--pct,50%));border-radius:4px;outline:none}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:22px;height:22px;background:#e8622a;border-radius:50%;cursor:pointer;box-shadow:0 2px 8px rgba(232,98,42,.4)}
.tgl-row{display:flex;align-items:center;justify-content:space-between;padding:16px;border:2px solid #e2e8f0;border-radius:12px;cursor:pointer;transition:border-color .2s}
.tgl-row.on{border-color:#e8622a;background:#fff5f0}
.tgl-sw{width:48px;height:26px;background:#e2e8f0;border-radius:13px;position:relative;transition:background .2s;flex-shrink:0}
.tgl-sw::after{content:'';position:absolute;top:3px;left:3px;width:20px;height:20px;background:#fff;border-radius:50%;transition:transform .2s;box-shadow:0 1px 4px rgba(0,0,0,.2)}
.tgl-row.on .tgl-sw{background:#e8622a}.tgl-row.on .tgl-sw::after{transform:translateX(22px)}
.q-nav{display:flex;gap:12px;margin-top:24px}
.btn-prev{flex:0;padding:14px 20px;border-radius:50px;border:2px solid #e2e8f0;background:#fff;cursor:pointer;font-weight:600;color:#64748b;transition:all .2s}
.btn-prev:hover{border-color:var(--primary);color:var(--primary)}
.btn-next{flex:1;padding:14px;border-radius:50px;border:none;background:linear-gradient(135deg,#e8622a,#ff8c5a);color:#fff;font-size:1rem;font-weight:700;cursor:pointer;box-shadow:0 4px 15px rgba(232,98,42,.3);transition:all .2s}
.btn-next:hover{transform:translateY(-2px)}
#results{display:none}
.res-hdr{background:var(--primary);color:#fff;padding:20px}
.res-title{font-size:1.3rem;font-weight:700;margin-bottom:4px}
.res-sub{font-size:.85rem;color:rgba(255,255,255,.7)}
.filters-bar{background:#fff;padding:16px 20px;border-bottom:1px solid #e2e8f0;display:flex;gap:8px;overflow-x:auto;scrollbar-width:none;-webkit-overflow-scrolling:touch}
.filters-bar::-webkit-scrollbar{display:none}
.f-chip{flex-shrink:0;padding:8px 16px;border-radius:20px;border:2px solid #e2e8f0;background:#fff;font-size:.8rem;font-weight:600;cursor:pointer;color:#64748b;transition:all .2s;white-space:nowrap}
.f-chip.active{border-color:var(--primary);background:var(--primary);color:#fff}
#map-container{height:260px}
#map{height:100%}
.sort-row{background:#fff;padding:12px 20px;display:flex;align-items:center;gap:12px;border-bottom:1px solid #e2e8f0}
.sort-sel{flex:1;padding:8px 12px;border:1px solid #e2e8f0;border-radius:8px;font-size:.85rem;color:#334155;outline:none}
.res-count{font-size:.8rem;color:#64748b;font-weight:600;margin-left:auto}
.poi-list{padding:16px 20px;display:grid;gap:16px;padding-bottom:80px}
.poi-card{background:var(--card-bg);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow);transition:transform .2s,box-shadow .2s;cursor:pointer}
.poi-card:hover{transform:translateY(-3px);box-shadow:0 8px 30px rgba(0,0,0,.15)}
.poi-hdr{padding:16px;display:flex;gap:14px;align-items:flex-start}
.poi-ic{width:52px;height:52px;border-radius:12px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:1.6rem}
.poi-info{flex:1;min-width:0}
.poi-name{font-weight:700;font-size:1rem;color:#1a1a2e;margin-bottom:4px;line-height:1.2}
.poi-meta{font-size:.78rem;color:#64748b;margin-bottom:8px}
.badges{display:flex;gap:6px;flex-wrap:wrap}
.bdg{font-size:.68rem;font-weight:700;padding:3px 8px;border-radius:6px;text-transform:uppercase;letter-spacing:.5px}
.bg{background:#dcfce7;color:#15803d}.bb{background:#dbeafe;color:#1d4ed8}.bo{background:#fef3c7;color:#b45309}
.poi-transp{padding:10px 16px;background:#f8fafc;border-top:1px solid #f1f5f9;display:grid;grid-template-columns:1fr 1fr;gap:8px}
.tr-item{display:flex;align-items:center;gap:6px;font-size:.78rem;color:#64748b}
.poi-acts{padding:12px 16px;background:#fff;border-top:1px solid #f1f5f9;display:flex;gap:8px}
.btn-gm{flex:1;padding:10px;border-radius:10px;border:none;background:#4285f4;color:#fff;font-size:.8rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;text-decoration:none;transition:all .2s}
.btn-gm:hover{background:#1a73e8;transform:translateY(-1px)}
.btn-gm.tr{background:#34a853}.btn-gm.tr:hover{background:#0d7a3e}
.btn-det{padding:10px 14px;border-radius:10px;border:2px solid #e2e8f0;background:#fff;font-size:.8rem;font-weight:700;cursor:pointer;color:#64748b;transition:all .2s}
.btn-det:hover{border-color:var(--primary);color:var(--primary)}
#detail-page{display:none;position:fixed;inset:0;background:var(--light);z-index:2000;overflow-y:auto}
.det-hdr{background:var(--primary);color:#fff;padding:20px;position:sticky;top:0;z-index:10;display:flex;align-items:center;gap:12px}
.det-back{background:rgba(255,255,255,.15);border:none;color:#fff;width:38px;height:38px;border-radius:50%;font-size:1.2rem;cursor:pointer;display:flex;align-items:center;justify-content:center}
.det-back:hover{background:rgba(255,255,255,.25)}
.det-body{padding:20px;max-width:680px;margin:0 auto}
.det-ic-row{display:flex;align-items:center;gap:16px;margin-bottom:20px}
.det-ic-big{width:72px;height:72px;border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:2.4rem;flex-shrink:0}
.det-name{font-size:1.4rem;font-weight:800;color:var(--primary);margin-bottom:4px}
.det-cat{font-size:.85rem;color:#64748b;font-weight:600;text-transform:uppercase;letter-spacing:1px}
.det-sec{background:var(--card-bg);border-radius:var(--radius);padding:20px;margin-bottom:16px;box-shadow:0 2px 10px rgba(0,0,0,.06)}
.det-sec-ttl{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:#e8622a;margin-bottom:14px}
.det-row{display:flex;align-items:flex-start;gap:12px;padding:8px 0;border-bottom:1px solid #f1f5f9;font-size:.88rem}
.det-row:last-child{border-bottom:none;padding-bottom:0}
.det-row-ic{font-size:1.1rem;flex-shrink:0;margin-top:2px}
.det-lbl{color:#94a3b8;font-size:.78rem}.det-val{font-weight:600;color:#1a1a2e}.det-sub{font-size:.78rem;color:#64748b;margin-top:2px}
.btn-big{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:14px;border-radius:12px;border:none;font-size:.95rem;font-weight:700;cursor:pointer;margin-bottom:10px;text-decoration:none;transition:all .2s}
.btn-big.car{background:#4285f4;color:#fff}.btn-big.car:hover{background:#1a73e8}
.btn-big.trs{background:#34a853;color:#fff}.btn-big.trs:hover{background:#0d7a3e}
.btn-big.place{background:#ff5252;color:#fff}.btn-big.place:hover{background:#d32f2f}
.nearby-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.nearby-card{background:var(--light);border-radius:10px;padding:12px;cursor:pointer;border:1px solid #e2e8f0;transition:all .2s;display:flex;align-items:center;gap:10px}
.nearby-card:hover{border-color:var(--primary);background:#eff6ff}
#rando-page{display:none;padding-bottom:80px}
.rando-filters{background:#fff;padding:16px 20px;border-bottom:1px solid #e2e8f0;display:flex;gap:8px;overflow-x:auto;scrollbar-width:none}
.rando-filters::-webkit-scrollbar{display:none}
.rando-card{margin:0 20px 16px;background:var(--card-bg);border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden}
.rando-banner{height:100px;display:flex;align-items:center;justify-content:center;font-size:3rem;position:relative}
.rando-diff{position:absolute;top:12px;right:12px;padding:4px 10px;border-radius:8px;font-size:.75rem;font-weight:700;background:rgba(0,0,0,.5);color:#fff}
.rando-body{padding:16px}
.rando-name{font-size:1.05rem;font-weight:700;color:var(--primary);margin-bottom:8px}
.rando-stats{display:flex;gap:16px;margin-bottom:12px;flex-wrap:wrap}
.rando-stat{display:flex;align-items:center;gap:5px;font-size:.82rem;color:#64748b}
.rando-stat strong{color:#334155;font-size:.9rem}
.rando-warn{font-size:.75rem;color:#92400e;background:#fef3c7;border-radius:8px;padding:8px 10px;margin-top:10px;display:flex;gap:6px}
.load-ov{position:fixed;inset:0;background:rgba(26,58,92,.92);z-index:3000;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:20px;color:#fff}
.spin{width:52px;height:52px;border:4px solid rgba(255,255,255,.2);border-top-color:#e8622a;border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.load-txt{font-size:1rem;font-weight:600}.load-sub{font-size:.8rem;opacity:.6;text-align:center;max-width:280px}
.empty-st{text-align:center;padding:48px 24px;color:#94a3b8}
.empty-st .ic{font-size:3rem;margin-bottom:12px}
.empty-st h3{font-size:1.1rem;font-weight:700;color:#64748b;margin-bottom:8px}
#agenda-page{display:none;padding:20px;padding-bottom:80px}
.ag-wrap{background:var(--card-bg);border-radius:var(--radius);padding:28px;box-shadow:var(--shadow);text-align:center}
.ag-src{display:flex;align-items:flex-start;gap:10px;padding:10px;border-radius:8px;background:var(--light);margin-bottom:8px;font-size:.82rem;text-align:left}
.src-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:4px}
.s-ok{background:#22c55e}.s-pend{background:#f59e0b}.s-miss{background:#ef4444}
.fav-btn{background:none;border:none;font-size:1.4rem;cursor:pointer;padding:4px;transition:transform .2s}
.fav-btn:hover{transform:scale(1.2)}
.data-notice{background:#fffbeb;border:1px solid #fcd34d;border-radius:10px;padding:10px 14px;margin:0 20px 16px;font-size:.78rem;color:#92400e;display:flex;gap:8px;align-items:flex-start;line-height:1.5}
.bnav{position:fixed;bottom:0;left:0;right:0;z-index:1000;background:rgba(255,255,255,.97);backdrop-filter:blur(12px);border-top:1px solid #e2e8f0;display:flex;box-shadow:0 -4px 20px rgba(0,0,0,.08)}
.bnav-item{flex:1;display:flex;flex-direction:column;align-items:center;padding:10px 4px 6px;cursor:pointer;color:#94a3b8;font-size:.65rem;font-weight:600;gap:3px;border:none;background:none;text-transform:uppercase;letter-spacing:.5px;transition:color .2s}
.bnav-item .ni{font-size:1.4rem}
.bnav-item.active{color:#e8622a}
.api-st{display:flex;align-items:center;gap:6px;font-size:.78rem;padding:8px 12px;border-radius:8px;margin-top:8px}
.api-st.ok{background:rgba(34,197,94,.15);color:#86efac}
.api-st.err{background:rgba(239,68,68,.15);color:#fca5a5}
.api-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.ad-ok{background:#22c55e}.ad-err{background:#ef4444}
.osm-attr{font-size:.7rem;color:#94a3b8;padding:4px 10px;background:#f8fafc;border-top:1px solid #e2e8f0;text-align:right}
.osm-attr a{color:#94a3b8}
.hidden{display:none!important}
</style>
</head>
<body>

<!-- ── LANDING ── -->
<div id="landing">
  <canvas id="canvas3d"></canvas>
  <div id="ptcls" style="position:absolute;inset:0;pointer-events:none"></div>
  <div class="lc">
    <div class="badge-hero">✨ Anti-ennui · Vesoul &amp; Haute-Saône</div>
    <h1 class="hero">Que faire<br>autour de <span>Vesoul</span>&nbsp;?</h1>
    <p class="hero-sub">Activités, restaurants, randonnées, bien-être… jusqu'à 60 km. Itinéraires voiture et transports Moova inclus.</p>
    <button class="btn-cta" onclick="startApp()">Commencer le questionnaire →</button>
    <p style="margin-top:16px;color:rgba(255,255,255,.3);font-size:.75rem">OpenStreetMap · Moova GTFS · Open Data</p>
  </div>
  <div class="scroll-hint"><div>▼</div><div>Explorer</div></div>
</div>

<!-- ── LOADING ── -->
<div class="load-ov hidden" id="loading">
  <div class="spin"></div>
  <div class="load-txt" id="ltxt">Chargement…</div>
  <div class="load-sub" id="lsub">Interrogation Overpass API…</div>
</div>

<!-- ── APP ── -->
<div id="app">
  <nav class="nav">
    <div class="nav-logo">Vesoul <span>Anti-Ennui</span></div>
    <button class="nav-btn" onclick="goHome()">🏠</button>
    <button class="nav-btn" onclick="showRando()">🥾</button>
    <button class="nav-btn" onclick="showAgenda()">📅</button>
    <button class="nav-btn" onclick="showFavs()">❤️</button>
  </nav>

  <!-- Questionnaire -->
  <div id="questionnaire">
    <div><div class="step-ind"><span id="slbl">Étape 1 / 9</span><span id="spct">0 %</span></div>
    <div class="prog-bar"><div class="prog-fill" id="pfill" style="width:11%"></div></div></div>
    <div id="qcont"></div>
  </div>

  <!-- Results -->
  <div id="results">
    <div class="res-hdr">
      <div class="res-title" id="rtitle">Résultats</div>
      <div class="res-sub" id="rsub">Chargement…</div>
      <div id="apist"></div>
    </div>
    <div class="filters-bar" id="fbar"></div>
    <div id="map-container"><div id="map"></div></div>
    <div class="osm-attr">Carte : © <a href="https://www.openstreetmap.org/copyright" target="_blank">OpenStreetMap</a> contributors</div>
    <div class="sort-row">
      <span style="font-size:.8rem;color:#64748b;font-weight:600;white-space:nowrap">Trier :</span>
      <select class="sort-sel" id="sortsel" onchange="doSort()">
        <option value="score">Recommandé</option>
        <option value="distance">Plus proche</option>
        <option value="name">Alphabétique</option>
      </select>
      <span class="res-count" id="rcnt"></span>
    </div>
    <div class="data-notice">ℹ️ <span>Données <strong>OpenStreetMap</strong> via Overpass API. Informations manquantes affichées "Non disponible" — jamais inventées.</span></div>
    <div class="poi-list" id="poilist"></div>
  </div>

  <!-- Detail -->
  <div id="detail-page">
    <div class="det-hdr">
      <button class="det-back" onclick="closeDetail()">←</button>
      <span id="dettitle" style="font-size:1.1rem;font-weight:700">Détails</span>
    </div>
    <div class="det-body" id="detbody"></div>
  </div>

  <!-- Rando -->
  <div id="rando-page">
    <div class="res-hdr">
      <div class="res-title">🥾 Randonnées</div>
      <div class="res-sub">Circuits autour de Vesoul · Sources OSM &amp; terrain</div>
    </div>
    <div class="rando-filters" id="rfilt"></div>
    <div id="rlist" style="padding:16px 0"></div>
  </div>

  <!-- Agenda -->
  <div id="agenda-page">
    <h2 style="font-size:1.2rem;font-weight:800;color:var(--primary);margin-bottom:16px">📅 Agenda local</h2>
    <div class="ag-wrap">
      <div style="font-size:3rem;margin-bottom:12px">📅</div>
      <div style="font-size:1.1rem;font-weight:700;color:var(--primary);margin-bottom:8px">Module Agenda prêt à connecter</div>
      <div style="font-size:.85rem;color:#64748b;line-height:1.6;margin-bottom:20px">Données jamais inventées — ce module reçoit des flux officiels vérifiés.</div>
      <div style="text-align:left">
        <div style="font-size:.8rem;font-weight:700;color:#64748b;margin-bottom:8px;text-transform:uppercase;letter-spacing:1px">Sources à connecter</div>
        <div class="ag-src"><div class="src-dot s-pend"></div><div><strong>Office de Tourisme Vesoul-Val de Saône</strong><br><span style="color:#64748b">Flux ICS/JSON officiel — en attente</span></div></div>
        <div class="ag-src"><div class="src-dot s-pend"></div><div><strong>vesoul.fr/agenda</strong><br><span style="color:#64748b">Scraping ou API municipale requise</span></div></div>
        <div class="ag-src"><div class="src-dot s-miss"></div><div><strong>Événements OSM node[event]</strong><br><span style="color:#64748b">Données rares — en veille</span></div></div>
        <div class="ag-src"><div class="src-dot s-ok"></div><div><strong>data.gouv.fr — Culture Haute-Saône</strong><br><span style="color:#64748b">API disponible — prêt à importer</span></div></div>
      </div>
    </div>
  </div>

  <!-- Bottom Nav -->
  <nav class="bnav">

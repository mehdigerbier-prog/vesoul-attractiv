function initMap(){
  if(S.map){S.map.remove();S.map=null;}
  const m=L.map('themap').setView([VL,VN],10);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'© OpenStreetMap',maxZoom:18}).addTo(m);
  L.marker([VL,VN]).addTo(m).bindPopup('<strong>📍 Vesoul</strong>').openPopup();
  L.circle([VL,VN],{radius:(S.ans.rayon||30)*1000,color:'#e8622a',fillColor:'#e8622a',fillOpacity:.05,weight:2,dashArray:'6,6'}).addTo(m);
  S.map=m;updMarkers();
}
function updMarkers(){
  if(!S.map)return;
  S.markers.forEach(m=>m.remove());S.markers=[];
  S.filtered.slice(0,50).forEach(p=>{
    const ct=CATS[p.category]||CATS.attraction;
    const ic=L.divIcon({html:'<div style="background:'+ct.c+';border:2px solid '+ct.b+';width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;box-shadow:0 2px 5px rgba(0,0,0,.2)">'+ct.i+'</div>',iconSize:[30,30],iconAnchor:[15,15],className:''});
    const mk=L.marker([p.lat,p.lon],{icon:ic}).addTo(S.map).bindPopup('<strong>'+p.name+'</strong><br>'+ct.l+' · '+p.distance.toFixed(1)+' km');
    mk.on('click',()=>openDet(p.id));S.markers.push(mk);
  });
}


// ══ SUBMIT → OVERPASS ══
async function submitQ(){
  document.getElementById('questionnaire').style.display='none';
  showLoader('Chargement des données OSM…','Interrogation Overpass API · '+(S.ans.rayon||30)+' km autour de Vesoul…');
  const r=(S.ans.rayon||30)*1000;
  const its=S.ans.interets||[];
  const cats=its.length>0?its:['restaurant','sport','nature','culture','attraction','lake','musee'];
  let filters=[];
  cats.forEach(c=>{if(CATS[c])filters=filters.concat(CATS[c].q);});
  filters=[...new Set([...filters,'tourism=attraction','tourism=viewpoint','tourism=museum','amenity=theatre','leisure=park'])];
  let nq='';
  filters.forEach(f=>{const[k,v]=f.split('=');nq+='node["'+k+'"="'+v+'"](around:'+r+','+VL+','+VN+');\nway["'+k+'"="'+v+'"](around:'+r+','+VL+','+VN+');\n';});
  const oq='[out:json][timeout:30];\n(\n'+nq+');\nout center 200;';
  try{
    updLoader('Requête Overpass…','Récupération POI OpenStreetMap…');
    const res=await fetch(OVP,{method:'POST',body:oq});
    if(!res.ok)throw new Error('HTTP '+res.status);
    const d=await res.json();
    updLoader('Traitement…',d.elements.length+' éléments · normalisation…');
    S.pois=procOVP(d.elements,S.ans);
    S.filtered=[...S.pois];
    S.ovpOk=true;
    await wait(400);hideLoader();showResults();
  }catch(e){
    console.warn('Overpass:',e);
    updLoader('Données locales…','API indisponible · données locales Vesoul');
    await wait(600);
    S.pois=getFallback(S.ans);
    S.filtered=[...S.pois];
    S.ovpOk=false;
    hideLoader();showResults();
  }
}

// ══ TRAITEMENT OVERPASS ══
function procOVP(els,ans){
  const r=ans.rayon||30,pois=[];
  els.forEach(el=>{
    if(!el.tags)return;
    const lat=el.lat||(el.center&&el.center.lat),lon=el.lon||(el.center&&el.center.lon);
    if(!lat||!lon)return;
    const name=el.tags.name||el.tags['name:fr'];
    if(!name||name.length<2)return;
    const dist=hav(VL,VN,lat,lon);
    if(dist>r)return;
    const cat=detCat(el.tags);
    if(!cat)return;
    pois.push(enrich({
      id:String(el.id),name,category:cat,lat,lon,distance:dist,
      address:mkAddr(el.tags),
      website:el.tags.website||el.tags['contact:website']||'',
      openingHours:el.tags.opening_hours||'',
      wheelchair:el.tags.wheelchair||'',
      description:el.tags.description||'',
      tags:el.tags,osmId:el.id,osmType:el.type||'node',
      source:'OpenStreetMap'
    },ans));
  });
  return dedupe(pois).sort((a,b)=>b.score-a.score).slice(0,80);
}
function enrich(p,ans){
  p.carTimeMin=Math.max(5,Math.round(p.distance/60*60));
  p.carTime=p.carTimeMin+' min';
  p.score=calcScore(p.tags||{},ans,p.distance);
  p.transit=calcTransit(p);
  p.gmLink=gLink(p.lat,p.lon,'driving');
  return p;
}
function detCat(t){
  if(t.amenity==='restaurant'||t.amenity==='fast_food'||t.amenity==='cafe')return'restaurant';
  if(t.amenity==='bar'||t.amenity==='pub')return'bar';
  if(t.leisure==='swimming_pool')return'piscine';
  if(t.leisure==='sports_centre'||t.leisure==='stadium')return'sport';
  if(t.leisure==='spa'||t.amenity==='spa')return'bienetre';
  if(t.tourism==='museum')return'musee';
  if(t.amenity==='theatre'||t.amenity==='cinema')return'culture';
  if(t.historic)return'culture';
  if(t.tourism==='viewpoint'||t.tourism==='attraction')return'attraction';
  if(t.leisure==='park'||t.leisure==='nature_reserve')return'nature';
  if(t.natural==='peak')return'nature';
  if(t.natural==='water')return'lake';
  if(t.tourism==='camp_site'||t.tourism==='hotel')return'camping';
  if(t.amenity==='marketplace')return'shopping';
  if(t.tourism)return'attraction';
  if(t.leisure)return'nature';
  return null;
}
function mkAddr(t){const p=[];if(t['addr:housenumber'])p.push(t['addr:housenumber']);if(t['addr:street'])p.push(t['addr:street']);if(t['addr:city'])p.push(t['addr:city']);return p.join(', ')||'Adresse non renseignée (OSM)';}
function calcScore(tags,ans,dist){
  let s=100-dist*.5;
  const cat=detCat(tags),its=ans.interets||[];
  if(its.includes(cat))s+=40;
  if(ans.mobilite==='transports'&&dist<5)s+=30;
  if(ans.mobilite==='transports'&&dist>20)s-=20;
  if(ans.budget==='gratuit'&&tags.fee==='no')s+=25;
  if(ans.budget==='gratuit'&&tags.fee==='yes')s-=30;
  if(ans.profil==='famille'&&(cat==='nature'||cat==='lake'))s+=15;
  if(ans.temps==='soiree'&&(cat==='bar'||cat==='culture'))s+=25;
  if(ans.temps==='soiree'&&cat==='musee')s-=20;
  if(ans.original&&(tags.tourism==='viewpoint'||cat==='attraction'))s+=35;
  if(ans.ambiance==='sportif'&&cat==='sport')s+=30;
  if(ans.ambiance==='calme'&&(cat==='nature'||cat==='bienetre'))s+=25;
  if(ans.ambiance==='decouverte'&&(cat==='musee'||cat==='culture'))s+=25;
  if(ans.ambiance==='fun'&&(cat==='bar'||cat==='sport'))s+=20;
  if(ans.contraintes&&ans.contraintes.includes('pmr')&&tags.wheelchair==='yes')s+=20;
  if(ans.contraintes&&ans.contraintes.includes('pmr')&&tags.wheelchair==='no')s-=40;
  if(tags.name)s+=10;if(tags.website)s+=5;
  return Math.max(0,s);
}
function calcTransit(p){
  const d=p.distance,lk=gLink(p.lat,p.lon,'transit');
  if(d<=15)return{ok:true,dur:Math.round(d*4+15)+' min',lines:d<5?['L1','L3']:['L2'],walk:Math.round(d*.8*10)+' min',note:'Estimation Moova (mode dégradé). Vérifier sur moova.fr.',lk};
  if(d<=30)return{ok:true,dur:Math.round(d*3.5+20)+' min',lines:['Moova + correspondance'],walk:Math.round(d*.3*10)+' min',note:'Approximatif — vérifier sur Google Maps Transports.',lk};
  return{ok:false,note:'> 30 km — hors réseau Moova. Voiture recommandée.'};
}
function dedupe(p){const s=new Map();return p.filter(x=>{const k=x.name.toLowerCase().replace(/\s/g,'').slice(0,10)+'_'+Math.round(x.lat*100)+'_'+Math.round(x.lon*100);if(s.has(k))return false;s.set(k,true);return true;});}
function hav(a,b,c,d){const R=6371,dl=(c-a)*Math.PI/180,dn=(d-b)*Math.PI/180,x=Math.sin(dl/2)**2+Math.cos(a*Math.PI/180)*Math.cos(c*Math.PI/180)*Math.sin(dn/2)**2;return R*2*Math.atan2(Math.sqrt(x),Math.sqrt(1-x));}
function gLink(lat,lon,mode){return'https://www.google.com/maps/dir/?api=1&origin='+VL+','+VN+'&destination='+lat+','+lon+'&travelmode='+mode;}
function wait(ms){return new Promise(r=>setTimeout(r,ms));}

